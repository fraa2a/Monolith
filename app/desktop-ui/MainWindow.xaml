<Window
    x:Class="Monolith.Settings.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="Monolith Settings">

    <Grid x:Name="RootLayout" Background="#111111">
        <NavigationView
            x:Name="RootNav"
            PaneDisplayMode="Left"
            IsBackButtonVisible="Collapsed"
            IsSettingsVisible="False"
            OpenPaneLength="250"
            CompactPaneLength="56"
            SelectionChanged="OnNavSelectionChanged">
            <NavigationView.MenuItems>
                <NavigationViewItem x:Name="NavBasic" Content="Basic Settings" Tag="Basic" IsSelected="True" />
                <NavigationViewItem x:Name="NavOutput" Content="Output Settings" Tag="Output" />
                <NavigationViewItem x:Name="NavHotkeys" Content="Hotkeys" Tag="Hotkeys" />
                <NavigationViewItem Content="Capture" Tag="Capture" IsEnabled="False" />
                <NavigationViewItem Content="Audio" Tag="Audio" IsEnabled="False" />
                <NavigationViewItem Content="Encoding" Tag="Encoding" IsEnabled="False" />
                <NavigationViewItem Content="Advanced" Tag="Advanced" IsEnabled="False" />
            </NavigationView.MenuItems>

            <Border Padding="32,24,32,24">
                <Grid RowSpacing="22">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Spacing="4">
                    <TextBlock Text="{Binding PageTitle}" FontSize="28" FontWeight="SemiBold" Foreground="#F6F6F6" />
                    <TextBlock Text="{Binding PageSubtitle}" FontSize="14" Foreground="#BDBDBD" />
                    <InfoBar
                        Margin="0,14,0,0"
                        IsOpen="{Binding HasStatusMessage}"
                        Severity="{Binding StatusSeverity}"
                        Message="{Binding StatusMessage}" />
                </StackPanel>

                <ScrollViewer Grid.Row="1">
                    <Grid>
                        <StackPanel x:Name="BasicPage" Spacing="18">
                            <Border Background="#242424" CornerRadius="12" Padding="22">
                                <StackPanel Spacing="16">
                                    <TextBlock Text="Replay Buffer" FontSize="18" FontWeight="SemiBold" Foreground="#FFFFFF" />
                                    <Grid ColumnSpacing="18">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="180" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="Duration seconds" Foreground="#FFFFFF" />
                                            <TextBlock Text="Saved clips use this replay window. Applies live after save." Foreground="#BDBDBD" TextWrapping="Wrap" />
                                        </StackPanel>
                                        <TextBox Grid.Column="1" Text="{Binding ReplayDurationSeconds, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    </Grid>
                                    <Grid ColumnSpacing="18">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="180" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="Memory budget MB" Foreground="#FFFFFF" />
                                            <TextBlock Text="Ring-buffer cap for encoded packets. Applies live after save." Foreground="#BDBDBD" TextWrapping="Wrap" />
                                        </StackPanel>
                                        <TextBox Grid.Column="1" Text="{Binding ReplayMemoryBudgetMb, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <Border Background="#242424" CornerRadius="12" Padding="22">
                                <StackPanel Spacing="8">
                                    <TextBlock Text="App Behavior" FontSize="18" FontWeight="SemiBold" Foreground="#FFFFFF" />
                                    <TextBlock Text="Startup, tray behavior, language, and logging controls are reserved for a later pass." Foreground="#BDBDBD" TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <StackPanel x:Name="OutputPage" Spacing="18" Visibility="Collapsed">
                            <Border Background="#242424" CornerRadius="12" Padding="22">
                                <StackPanel Spacing="16">
                                    <TextBlock Text="Clip Storage" FontSize="18" FontWeight="SemiBold" Foreground="#FFFFFF" />
                                    <Grid ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBox Header="Replay clip folder" Text="{Binding ClipsDirectory, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        <Button Grid.Column="1" Content="Browse" VerticalAlignment="Bottom" Click="OnBrowseClips" />
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <Border Background="#242424" CornerRadius="12" Padding="22">
                                <StackPanel Spacing="16">
                                    <TextBlock Text="Recording Storage" FontSize="18" FontWeight="SemiBold" Foreground="#FFFFFF" />
                                    <Grid ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBox Header="Manual recording folder" Text="{Binding RecordingsDirectory, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        <Button Grid.Column="1" Content="Browse" VerticalAlignment="Bottom" Click="OnBrowseRecordings" />
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <StackPanel x:Name="HotkeysPage" Spacing="18" Visibility="Collapsed">
                            <Border Background="#242424" CornerRadius="12" Padding="22">
                                <StackPanel Spacing="14">
                                    <TextBlock Text="Global Hotkeys" FontSize="18" FontWeight="SemiBold" Foreground="#FFFFFF" />
                                    <Grid ColumnSpacing="16" RowSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="220" />
                                            <ColumnDefinition Width="220" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <TextBlock Grid.Row="0" Text="Save replay" VerticalAlignment="Center" Foreground="#FFFFFF" />
                                        <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding SaveReplayHotkey}" IsReadOnly="True" />
                                        <TextBlock Grid.Row="1" Text="Start recording" VerticalAlignment="Center" Foreground="#FFFFFF" />
                                        <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding RecordingStartHotkey}" IsReadOnly="True" />
                                        <TextBlock Grid.Row="2" Text="Stop recording" VerticalAlignment="Center" Foreground="#FFFFFF" />
                                        <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding RecordingStopHotkey}" IsReadOnly="True" />
                                        <TextBlock Grid.Row="3" Text="Pause / resume" VerticalAlignment="Center" Foreground="#FFFFFF" />
                                        <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding PauseResumeHotkey}" IsReadOnly="True" />
                                    </Grid>
                                    <InfoBar
                                        IsOpen="True"
                                        Severity="Informational"
                                        Message="Hotkey rebinding is intentionally disabled until conflict detection is wired." />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Grid>
                </ScrollViewer>

                <Grid Grid.Row="2">
                    <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Right">
                        <Button Content="Cancel" Click="OnCancel" />
                        <Button Content="Save" Style="{StaticResource AccentButtonStyle}" Click="OnSave" />
                    </StackPanel>
                </Grid>
                </Grid>
            </Border>
        </NavigationView>
    </Grid>
</Window>
