<Window
    x:Class="Monolith.Settings.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="Monolith Settings">

    <Grid x:Name="RootLayout" Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <NavigationView
            x:Name="RootNav"
            PaneDisplayMode="Left"
            IsBackButtonVisible="Collapsed"
            IsSettingsVisible="False"
            OpenPaneLength="220"
            CompactPaneLength="56"
            SelectionChanged="OnNavSelectionChanged">
            <NavigationView.MenuItems>
                <NavigationViewItem x:Name="NavGeneral"  Content="General"  Tag="General"  IsSelected="True">
                    <NavigationViewItem.Icon><FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE713;" /></NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem x:Name="NavOutput"   Content="Output"   Tag="Output">
                    <NavigationViewItem.Icon><FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE838;" /></NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem x:Name="NavClip"     Content="Clip"     Tag="Clip">
                    <NavigationViewItem.Icon><FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE786;" /></NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem x:Name="NavCapture"  Content="Capture"  Tag="Capture">
                    <NavigationViewItem.Icon><FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE722;" /></NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem x:Name="NavAudio"    Content="Audio"    Tag="Audio">
                    <NavigationViewItem.Icon><FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE767;" /></NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem x:Name="NavHotkeys"  Content="Hotkeys"  Tag="Hotkeys">
                    <NavigationViewItem.Icon><FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE92E;" /></NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem x:Name="NavAdvanced" Content="Advanced" Tag="Advanced">
                    <NavigationViewItem.Icon><FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE9E9;" /></NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.MenuItems>

            <Border Padding="32,24,32,24">
                <Grid RowSpacing="22">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- Page header -->
                    <StackPanel Grid.Row="0" Spacing="4">
                        <TextBlock Text="{Binding PageTitle}" FontSize="28" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                        <TextBlock Text="{Binding PageSubtitle}" FontSize="14" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <InfoBar
                            x:Name="GlobalStatusBar"
                            Margin="0,14,0,0"
                            IsOpen="{Binding HasStatusMessage}"
                            Severity="{Binding StatusSeverity}"
                            Message="{Binding StatusMessage}" />
                    </StackPanel>

                    <!-- Page content -->
                    <ScrollViewer Grid.Row="1">
                        <Grid>

                            <!-- ══ GENERAL PAGE ══════════════════════════════════ -->
                            <StackPanel x:Name="GeneralPage" Spacing="18">
                                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="12" Padding="22">
                                    <StackPanel Spacing="14">
                                        <TextBlock Text="Monolith" FontSize="22" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                                        <TextBlock Text="Use the pages on the left to configure output, capture, recording, and hotkeys." Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                                    </StackPanel>
                                </Border>

                                <!-- Corrupt config warning — only shown when LoadWarning != null -->
                                <InfoBar
                                    x:Name="CorruptConfigBar"
                                    IsOpen="False"
                                    Severity="Warning"
                                    Title="Config file was corrupt"
                                    Message="The bad file has been backed up to config.json.bak. Defaults have been loaded." />
                            </StackPanel>

                            <!-- ══ OUTPUT PAGE ═══════════════════════════════════ -->
                            <StackPanel x:Name="OutputPage" Spacing="18" Visibility="Collapsed">
                                <InfoBar
                                    IsOpen="True"
                                    Severity="Informational"
                                    Message="Output folders and format apply to future clips and recordings." />
                                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="12" Padding="22">
                                    <StackPanel Spacing="16">
                                        <TextBlock Text="Clip Storage" FontSize="18" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                                        <Grid ColumnSpacing="8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBox
                                                Header="Replay clip folder"
                                                Text="{Binding ClipsDirectory, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                            <Button Grid.Column="1" Content="Browse" VerticalAlignment="Bottom" Click="OnBrowseClips" />
                                            <Button Grid.Column="2" Content="Reset" VerticalAlignment="Bottom" Click="OnResetClips" />
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="12" Padding="22">
                                    <StackPanel Spacing="16">
                                        <TextBlock Text="Recording Storage" FontSize="18" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                                        <Grid ColumnSpacing="8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBox
                                                Header="Manual recording folder"
                                                Text="{Binding RecordingsDirectory, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                            <Button Grid.Column="1" Content="Browse" VerticalAlignment="Bottom" Click="OnBrowseRecordings" />
                                            <Button Grid.Column="2" Content="Reset" VerticalAlignment="Bottom" Click="OnResetRecordings" />
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="12" Padding="22">
                                    <StackPanel Spacing="16">
                                        <TextBlock Text="Formats" FontSize="18" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                                        <Grid ColumnSpacing="16" RowSpacing="12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="180" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="Clips and recordings" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" />
                                            <ComboBox
                                                x:Name="RecordingFormatComboBox"
                                                Grid.Column="1"
                                                HorizontalAlignment="Stretch"
                                                SelectionChanged="OnRecordingFormatSelectionChanged">
                                                <ComboBoxItem Content="MKV (Matroska)" Tag="mkv" />
                                                <ComboBoxItem Content="MP4 (MPEG-4)" Tag="mp4" />
                                            </ComboBox>
                                        </Grid>
                                    </StackPanel>
                                </Border>
                            </StackPanel>

                            <!-- ══ CLIP PAGE ═════════════════════════════════════ -->
                            <StackPanel x:Name="ClipPage" Spacing="18" Visibility="Collapsed">
                                <InfoBar
                                    IsOpen="True"
                                    Severity="Success"
                                    Message="Scope: live replay-buffer reconfigure after save. Active recordings are not interrupted." />
                                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="12" Padding="22">
                                    <StackPanel Spacing="16">
                                        <TextBlock Text="Replay Buffer" FontSize="18" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                                        <Grid ColumnSpacing="18">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="180" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <TextBlock Text="Duration (seconds)" Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                                                <TextBlock Text="Saved clips use this replay window. Applies live after save." Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                                            </StackPanel>
                                            <TextBox Grid.Column="1" Text="{Binding ReplayDurationSeconds, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        </Grid>
                                        <Grid ColumnSpacing="18">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="180" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <TextBlock Text="Memory budget (MB)" Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                                                <TextBlock Text="Ring-buffer cap for encoded packets. Applies live after save." Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                                            </StackPanel>
                                            <TextBox Grid.Column="1" Text="{Binding ReplayMemoryBudgetMb, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        </Grid>
                                    </StackPanel>
                                </Border>

                            </StackPanel>

                            <!-- ══ CAPTURE PAGE ══════════════════════════════════ -->
                            <StackPanel x:Name="CapturePage" Spacing="18" Visibility="Collapsed">
                                <InfoBar
                                    IsOpen="True"
                                    Severity="Informational"
                                    Message="Scope: capture/encoder restart when no manual recording is active. Unsafe changes are deferred while recording." />

                                <!-- Monitor selection -->
                                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="12" Padding="22">
                                    <StackPanel Spacing="14">
                                        <TextBlock Text="Monitor" FontSize="18" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                                        <ComboBox
                                            x:Name="MonitorComboBox"
                                            Header="Capture monitor"
                                            HorizontalAlignment="Stretch"
                                            SelectionChanged="OnMonitorSelectionChanged" />
                                        <TextBlock
                                            x:Name="MonitorUnavailableNote"
                                            Text="Start Monolith once to detect monitors."
                                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                            FontSize="12"
                                            Visibility="Collapsed" />
                                    </StackPanel>
                                </Border>

                                <!-- Resolution -->
                                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="12" Padding="22">
                                    <StackPanel Spacing="14">
                                        <TextBlock Text="Resolution" FontSize="18" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                                        <ComboBox
                                            x:Name="ResolutionComboBox"
                                            Header="Output resolution"
                                            HorizontalAlignment="Stretch"
                                            SelectionChanged="OnResolutionSelectionChanged">
                                            <ComboBoxItem Content="Native (same as capture)" Tag="source" />
                                            <ComboBoxItem Content="1280 x 720" Tag="1280x720" />
                                            <ComboBoxItem Content="1920 x 1080" Tag="1920x1080" />
                                            <ComboBoxItem Content="2560 x 1440" Tag="2560x1440" />
                                            <ComboBoxItem Content="Custom…" Tag="custom" />
                                        </ComboBox>

                                        <StackPanel
                                            x:Name="CustomResolutionPanel"
                                            Orientation="Horizontal"
                                            Spacing="12"
                                            Visibility="Collapsed">
                                            <NumberBox
                                                x:Name="WidthBox"
                                                Header="Width"
                                                Minimum="128"
                                                Maximum="7680"
                                                SpinButtonPlacementMode="Compact"
                                                SmallChange="2"
                                                Value="{Binding ResolutionWidth, Mode=TwoWay}"
                                                ValueChanged="OnResolutionValueChanged"
                                                Width="160" />
                                            <NumberBox
                                                x:Name="HeightBox"
                                                Header="Height"
                                                Minimum="128"
                                                Maximum="4320"
                                                SpinButtonPlacementMode="Compact"
                                                SmallChange="2"
                                                Value="{Binding ResolutionHeight, Mode=TwoWay}"
                                                ValueChanged="OnResolutionValueChanged"
                                                Width="160" />
                                        </StackPanel>
                                    </StackPanel>
                                </Border>

                                <!-- Video encoder / quality -->
                                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="12" Padding="22">
                                    <StackPanel Spacing="14">
                                        <TextBlock Text="Video Encoder" FontSize="18" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                                        <ComboBox
                                            x:Name="EncoderComboBox"
                                            Header="Encoder"
                                            HorizontalAlignment="Stretch"
                                            SelectionChanged="OnEncoderSelectionChanged" />
                                        <StackPanel Spacing="4">
                                            <NumberBox
                                                x:Name="VideoFpsBox"
                                                Header="Recording FPS"
                                                Minimum="15"
                                                Maximum="120"
                                                SpinButtonPlacementMode="Compact"
                                                SmallChange="1"
                                                LargeChange="30"
                                                Value="{Binding VideoFps, Mode=TwoWay}"
                                                ValueChanged="OnVideoFpsValueChanged"
                                                Width="240"
                                                HorizontalAlignment="Left" />
                                            <NumberBox
                                                x:Name="QualityBox"
                                                Header="Video quality (10–30, lower = better)"
                                                Minimum="10"
                                                Maximum="30"
                                                SpinButtonPlacementMode="Compact"
                                                SmallChange="1"
                                                LargeChange="5"
                                                Value="{Binding VideoQuality, Mode=TwoWay}"
                                                ValueChanged="OnVideoQualityValueChanged"
                                                Width="240"
                                                HorizontalAlignment="Left" />
                                        </StackPanel>
                                    </StackPanel>
                                </Border>

                                <!-- Capture border -->
                                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="12" Padding="22">
                                    <StackPanel Spacing="10">
                                        <TextBlock Text="Capture Border" FontSize="18" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                                        <ToggleSwitch
                                            x:Name="CaptureBorderToggle"
                                            Header="Show Windows capture border"
                                            IsOn="{Binding ShowCaptureBorder, Mode=TwoWay}"
                                            Toggled="OnCaptureBorderToggled" />
                                        <TextBlock
                                            x:Name="BorderSuppressedWarning"
                                            Text="Windows denied border suppression on the last run; the yellow border may still appear."
                                            Foreground="#FFC107"
                                            TextWrapping="Wrap"
                                            FontSize="12"
                                            Visibility="Collapsed" />
                                    </StackPanel>
                                </Border>

                                <!-- Advanced FFmpeg options -->
                                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="12" Padding="22">
                                    <StackPanel Spacing="10">
                                        <TextBlock Text="Advanced" FontSize="18" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                                        <TextBox
                                            Header="Extra FFmpeg options"
                                            PlaceholderText="key=value:key=value"
                                            Text="{Binding ExtraFfmpegOptions, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        <InfoBar
                                            IsOpen="True"
                                            Severity="Warning"
                                            Message="Advanced encoder options, format key=value:key=value. Invalid options are dropped at startup and logged; they can make recording fail." />
                                    </StackPanel>
                                </Border>
                            </StackPanel>

                            <!-- ══ AUDIO PAGE ════════════════════════════════════ -->
                            <StackPanel x:Name="AudioPage" Spacing="18" Visibility="Collapsed">
                                <InfoBar
                                    IsOpen="True"
                                    Severity="Informational"
                                    Message="Scope: audio routing restart when no manual recording is active. Same-track multi-source mixing is not implemented yet." />

                                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="12" Padding="22">
                                    <StackPanel Spacing="14">
                                        <TextBlock Text="Mode" FontSize="18" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                                        <ComboBox
                                            x:Name="AudioModeComboBox"
                                            Header="Audio mode"
                                            HorizontalAlignment="Stretch"
                                            SelectionChanged="OnAudioModeSelectionChanged">
                                            <ComboBoxItem Content="Default: All Windows audio + microphone" Tag="default" />
                                            <ComboBoxItem Content="Custom: Per-channel audio setup" Tag="custom" />
                                        </ComboBox>
                                        <ComboBox
                                            x:Name="PrimaryMicComboBox"
                                            Header="Primary microphone for Default mode"
                                            HorizontalAlignment="Stretch"
                                            SelectionChanged="OnPrimaryMicSelectionChanged" />
                                    </StackPanel>
                                </Border>

                                <Border x:Name="ActiveGameStatusPanel" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="12" Padding="22" Visibility="Collapsed">
                                    <StackPanel Spacing="10">
                                        <TextBlock Text="Active Game Status" FontSize="16" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                                        <TextBlock x:Name="ActiveGameNameText" Text="Not detected" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                        <TextBlock x:Name="ActiveGameDetailsText" Text="" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12" TextWrapping="WrapWholeWords" />
                                    </StackPanel>
                                </Border>

                                <Border x:Name="CustomSourcesPanel" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="12" Padding="22" Visibility="Collapsed">
                                    <StackPanel Spacing="14">
                                        <TextBlock Text="Custom Sources" FontSize="18" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                                        <Grid ColumnSpacing="10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <ComboBox
                                                x:Name="AddAudioSourceComboBox"
                                                Header="Add source"
                                                HorizontalAlignment="Stretch" />
                                            <Button x:Name="AddAudioSourceButton" Grid.Column="1" Content="Add" VerticalAlignment="Bottom" Click="OnAddAudioSource" />
                                        </Grid>
                                        <Grid ColumnSpacing="18">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="260" />
                                            </Grid.ColumnDefinitions>
                                            <ListView
                                                x:Name="AudioSourcesList"
                                                MinHeight="180"
                                                SelectionChanged="OnAudioSourceSelectionChanged" />
                                            <StackPanel Grid.Column="1" Spacing="10">
                                                <TextBlock x:Name="SelectedAudioSourceName" Text="Select a source" FontWeight="SemiBold" />
                                                <ToggleSwitch
                                                    x:Name="AudioSourceEnabledToggle"
                                                    Header="Enabled"
                                                    Toggled="OnAudioSourceEnabledToggled" />
                                                <TextBlock Text="Tracks 1-6" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                                <Grid ColumnSpacing="8" RowSpacing="8">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="Auto" />
                                                    </Grid.RowDefinitions>
                                                    <CheckBox x:Name="AudioTrack1Box" Grid.Row="0" Grid.Column="0" MinWidth="72" Content="Track 1" Tag="1" Checked="OnAudioTrackChecked" Unchecked="OnAudioTrackChecked" />
                                                    <CheckBox x:Name="AudioTrack2Box" Grid.Row="0" Grid.Column="1" MinWidth="72" Content="Track 2" Tag="2" Checked="OnAudioTrackChecked" Unchecked="OnAudioTrackChecked" />
                                                    <CheckBox x:Name="AudioTrack3Box" Grid.Row="0" Grid.Column="2" MinWidth="72" Content="Track 3" Tag="3" Checked="OnAudioTrackChecked" Unchecked="OnAudioTrackChecked" />
                                                    <CheckBox x:Name="AudioTrack4Box" Grid.Row="1" Grid.Column="0" MinWidth="72" Content="Track 4" Tag="4" Checked="OnAudioTrackChecked" Unchecked="OnAudioTrackChecked" />
                                                    <CheckBox x:Name="AudioTrack5Box" Grid.Row="1" Grid.Column="1" MinWidth="72" Content="Track 5" Tag="5" Checked="OnAudioTrackChecked" Unchecked="OnAudioTrackChecked" />
                                                    <CheckBox x:Name="AudioTrack6Box" Grid.Row="1" Grid.Column="2" MinWidth="72" Content="Track 6" Tag="6" Checked="OnAudioTrackChecked" Unchecked="OnAudioTrackChecked" />
                                                </Grid>
                                                <Button Content="Remove source" Click="OnRemoveAudioSource" />
                                            </StackPanel>
                                        </Grid>
                                    </StackPanel>
                                </Border>
                            </StackPanel>

                            <!-- ══ HOTKEYS PAGE ══════════════════════════════════ -->
                            <StackPanel x:Name="HotkeysPage" Spacing="18" Visibility="Collapsed">
                                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="12" Padding="22">
                                    <StackPanel Spacing="14">
                                        <TextBlock Text="Global Hotkeys" FontSize="18" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                                        <Grid ColumnSpacing="12" RowSpacing="12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>
                                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Save replay" VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                                            <TextBox Grid.Row="0" Grid.Column="1" MaxWidth="280" Tag="SaveReplayHotkey" Text="{Binding SaveReplayHotkey}" IsReadOnly="True" GotFocus="OnHotkeyBoxGotFocus" LostFocus="OnHotkeyBoxLostFocus" />
                                            <Button Grid.Row="0" Grid.Column="2" Content="↺" Tag="SaveReplayHotkey" Click="OnResetHotkeyClick" ToolTipService.ToolTip="Reset to default" MinWidth="0" Padding="12,4" />
                                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Start recording" VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                                            <TextBox Grid.Row="1" Grid.Column="1" MaxWidth="280" Tag="RecordingStartHotkey" Text="{Binding RecordingStartHotkey}" IsReadOnly="True" GotFocus="OnHotkeyBoxGotFocus" LostFocus="OnHotkeyBoxLostFocus" />
                                            <Button Grid.Row="1" Grid.Column="2" Content="↺" Tag="RecordingStartHotkey" Click="OnResetHotkeyClick" ToolTipService.ToolTip="Reset to default" MinWidth="0" Padding="12,4" />
                                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Stop recording" VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                                            <TextBox Grid.Row="2" Grid.Column="1" MaxWidth="280" Tag="RecordingStopHotkey" Text="{Binding RecordingStopHotkey}" IsReadOnly="True" GotFocus="OnHotkeyBoxGotFocus" LostFocus="OnHotkeyBoxLostFocus" />
                                            <Button Grid.Row="2" Grid.Column="2" Content="↺" Tag="RecordingStopHotkey" Click="OnResetHotkeyClick" ToolTipService.ToolTip="Reset to default" MinWidth="0" Padding="12,4" />
                                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Pause / resume" VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                                            <TextBox Grid.Row="3" Grid.Column="1" MaxWidth="280" Tag="PauseResumeHotkey" Text="{Binding PauseResumeHotkey}" IsReadOnly="True" GotFocus="OnHotkeyBoxGotFocus" LostFocus="OnHotkeyBoxLostFocus" />
                                            <Button Grid.Row="3" Grid.Column="2" Content="↺" Tag="PauseResumeHotkey" Click="OnResetHotkeyClick" ToolTipService.ToolTip="Reset to default" MinWidth="0" Padding="12,4" />
                                        </Grid>
                                        <InfoBar
                                            IsOpen="True"
                                            Severity="Informational"
                                            Message="Scope: hotkeys reload live after save when Monolith is running." />
                                    </StackPanel>
                                </Border>
                            </StackPanel>

                            <!-- â•â• ADVANCED PAGE â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• -->
                            <StackPanel x:Name="AdvancedPage" Spacing="18" Visibility="Collapsed">
                                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="12" Padding="22">
                                    <StackPanel Spacing="14">
                                        <TextBlock Text="Components" FontSize="18" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                                        <ToggleSwitch
                                            x:Name="RecordingEnabledToggle"
                                            Header="Recording"
                                            Toggled="OnRecordingEnabledToggled" />
                                        <ToggleSwitch
                                            x:Name="ReplayBufferEnabledToggle"
                                            Header="Replay buffer"
                                            Toggled="OnReplayBufferEnabledToggled" />
                                        <TextBlock
                                            Text="Disable to reduce resource usage on low-end PCs. Disabled features appear greyed out in the tray menu."
                                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                            TextWrapping="Wrap"
                                            FontSize="12" />
                                        <InfoBar
                                            IsOpen="True"
                                            Severity="Informational"
                                            Message="Restart Monolith to fully apply component changes." />
                                    </StackPanel>
                                </Border>

                                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="12" Padding="22">
                                    <StackPanel Spacing="10">
                                        <TextBlock Text="Updates" FontSize="18" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                                        <ToggleSwitch
                                            x:Name="AutoCheckUpdatesToggle"
                                            Header="Check for updates automatically"
                                            Toggled="OnAutoCheckUpdatesToggled" />
                                        <TextBlock
                                            Text="Monolith checks for new versions in the background and asks before installing."
                                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                            TextWrapping="Wrap"
                                            FontSize="12" />
                                    </StackPanel>
                                </Border>

                                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="12" Padding="22">
                                    <StackPanel Spacing="10">
                                        <TextBlock Text="Startup" FontSize="18" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                                        <ToggleSwitch
                                            x:Name="AutoStartToggle"
                                            Header="Start Monolith when you sign in"
                                            Toggled="OnAutoStartToggled" />
                                        <TextBlock
                                            Text="Monolith runs in the background and can be controlled from the system tray."
                                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                            TextWrapping="Wrap"
                                            FontSize="12" />
                                    </StackPanel>
                                </Border>

                                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="12" Padding="22">
                                    <StackPanel Spacing="14">
                                        <TextBlock Text="Diagnostics" FontSize="18" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                                        <Grid ColumnSpacing="16" RowSpacing="10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="160" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>
                                            <TextBlock Grid.Row="0" Text="Config file" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" />
                                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding ConfigPath}" IsTextSelectionEnabled="True" FontFamily="Cascadia Mono, Consolas, monospace" FontSize="12" TextWrapping="Wrap" />
                                            <TextBlock Grid.Row="1" Text="Log file" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" />
                                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding LogFilePath}" IsTextSelectionEnabled="True" FontFamily="Cascadia Mono, Consolas, monospace" FontSize="12" TextWrapping="Wrap" />
                                        </Grid>
                                    </StackPanel>
                                </Border>
                            </StackPanel>

                        </Grid>
                    </ScrollViewer>

                    <!-- Bottom action bar -->
                    <Grid Grid.Row="2">
                        <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Right">
                            <Button Content="Cancel" Click="OnCancel" />
                            <Button Content="Save" Style="{StaticResource AccentButtonStyle}" Click="OnSave" />
                        </StackPanel>
                    </Grid>

                </Grid>
            </Border>
        </NavigationView>
    </Grid>
</Window>
