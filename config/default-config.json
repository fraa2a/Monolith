{
  "schema_version": 2,
  "capture": {
    "monitor_device": "",
    "resolution_mode": "source",
    "resolution_width": 0,
    "resolution_height": 0,
    "show_capture_border": false
  },
  "replay_buffer": {
    "duration_seconds": 30,
    "memory_budget_mb": 512,
    "save_container": "mkv"
  },
  "recording": {
    "container": "mkv",
    "pause_behavior": "timestamp_gap"
  },
  "video_encoder": {
    "backend": "auto",
    "bitrate_kbps": 20000,
    "extra_ffmpeg_options": ""
  },
  "output": {
    "clips_directory": "",
    "recordings_directory": "",
    "temp_directory": ""
  },
  "hotkeys": {
    "save_replay": "Ctrl+Shift+F8",
    "recording_start": "Ctrl+Shift+F9",
    "recording_stop": "Ctrl+Shift+F10",
    "pause_resume": "Ctrl+Shift+F11"
  }
}
